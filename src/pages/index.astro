---
import Layout from '../layouts/Layout.astro';
import { AlertTriangle } from 'lucide-react';

const menuOptions = [
  {
    href: '/general',
    topicNumber: 'Menú 01',
    topicLabel: 'Autoprotección General',
    badge: 'Temario General',
    image: '/assets/civil_safety_illustration_1774910214897.png',
    dashboardSummary: 'Acceso a los folletos originales de autoprotección ante sismos, lluvias, orden público y otros riesgos físicos.',
  },
  {
    href: '/menu-escolar',
    topicNumber: 'Menú 02',
    topicLabel: 'Menú Escolar (4 submenús)',
    badge: 'Seguridad Escolar',
    image: '/assets/1_classroom_2_students_3_teacher_4.jpg',
    dashboardSummary: 'Acceso agrupado a los cuatro módulos escolares: brigadas, PEGIR, evacuación/simulacros y señales de seguridad.',
  },
  {
    href: '/nuevo-contenido-submenus',
    topicNumber: 'Menú 03',
    topicLabel: 'Nueva Información (4 submenús)',
    badge: 'Nuevo Contenido',
    image: '/assets/the_group_of_people_are_gathered_around_a_large_map.jpg',
    dashboardSummary: 'Nueva base de información organizada en cuatro submenús independientes con el mismo contenido del modo integral.',
  },
  {
    href: '/nuevo-contenido-completo',
    topicNumber: 'Menú 04',
    topicLabel: 'Nueva Información (todo en uno)',
    badge: 'Nuevo Contenido',
    image: '/assets/a_group_of_people_gathered_around_a_large_map_the.jpg',
    dashboardSummary: 'La misma nueva información, consolidada en una sola vista para consulta completa en un único módulo.',
  },
];
---

<Layout title="Centro de Autoprotección - Gestión de Riesgos">
	<main class="min-h-screen bg-[var(--color-bg-light)]">
        <section class="relative overflow-hidden bg-[var(--color-secondary)] text-white">
            <div class="pc-dot-grid absolute inset-0 opacity-70"></div>
            <div class="absolute inset-0" style="background-image: var(--gradient-overlay), url('/assets/civil_safety_illustration_1774910214897.png'); background-size: cover; background-position: center;"></div>

            <div class="relative z-10 mx-auto max-w-6xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
                <div class="mb-5 flex flex-col gap-3 border-b border-white/15 pb-4 sm:mb-8">
                    <div class="flex items-center gap-3 sm:gap-4">
                        <div class="h-10 w-10 overflow-hidden rounded-full border border-white/30 bg-white p-1 sm:h-16 sm:w-16 sm:border-2 sm:p-1.5 shrink-0">
                            <img src="/assets/LOGO-PC-NUEVO-e1754668914257.png" alt="Logo Protección Civil" class="h-full w-full object-contain" />
                        </div>
                        <div>
                            <p class="mb-1 text-[0.62rem] font-semibold uppercase tracking-[0.12em] text-white/75 sm:text-sm sm:tracking-[0.2em]">Sistema de Autoprotección y Prevención</p>
                            <h1 class="text-xl font-black sm:text-4xl lg:text-5xl leading-tight">Seguridad y Gestión del Riesgo</h1>
                        </div>
                    </div>
                </div>

                <div class="grid gap-6 sm:gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(20rem,24rem)] lg:items-end">
                    <div class="max-w-3xl">
                        <div class="pc-ribbon mb-4 inline-flex items-center gap-2 px-3 py-1.5 text-[0.65rem] font-bold uppercase tracking-[0.12em] sm:px-4 sm:py-2 sm:text-xs">
                            <AlertTriangle size={12} strokeWidth={2.75} class="shrink-0" />
                            <span>Panel de Respuesta, Autoprotección y Prevención Escolar</span>
                        </div>
                        <h2 class="text-2xl font-black sm:text-4xl lg:text-5xl leading-tight">Seleccione un módulo operativo</h2>
                        <p class="mt-3 max-w-2xl text-xs leading-relaxed text-white/85 sm:text-base sm:leading-7">
                            Acceso directo a protocolos de autoprotección civil general y la nueva sección de seguridad en instituciones educativas.
                        </p>
                    </div>

                    <div class="pc-card pc-diagonal pc-hard-shadow relative hidden md:flex min-h-[10rem] lg:min-h-[12rem] overflow-hidden flex-col justify-end p-4 sm:p-6">
                        <div class="pc-card-image absolute inset-0" style="background-image: url('/assets/LOGO-PC-NUEVO-e1754668914257.png'); background-size: contain; background-repeat: no-repeat; background-position: center; opacity: 0.12;"></div>
                        <div class="relative z-10">
                            <h2 class="text-lg font-black text-white sm:text-xl">Módulos de Formación</h2>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="bg-white">
            <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
                <div class="pc-hazard-stripe mb-6 h-2 w-full sm:mb-8"></div>
                <div class="mb-6 flex flex-col items-start gap-3 sm:mb-8 sm:flex-wrap sm:items-end sm:justify-between sm:gap-4 lg:flex-row">
                    <div>
                        <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)] sm:text-sm sm:tracking-[0.2em]">Módulos Disponibles</p>
                        <h2 class="text-2xl font-black text-[var(--color-secondary)] sm:text-3xl">Guías e Instructivos de Seguridad</h2>
                    </div>
                </div>

                <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                    {menuOptions.map((option) => (
                        <a href={option.href} class="pc-card pc-diagonal pc-hard-shadow group relative flex flex-col min-h-[15rem] sm:min-h-[19rem] overflow-hidden transition-transform hover:translate-y-[-4px]">
                            <div class="pc-card-image absolute inset-0" style={`background-image: url('${option.image}'); background-size: cover; background-position: center;`}></div>
                            <div class="relative z-10 flex flex-1 flex-col justify-end p-4 sm:p-5">
                                <span class="pc-tag pc-tag-primary mb-2 w-fit">{option.badge}</span>
                                <span class="text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-white/60 mb-1">{option.topicNumber}</span>
                                <h3 class="text-lg font-black text-white sm:text-xl leading-tight">{option.topicLabel}</h3>
                                <p class="mt-2 text-xs leading-relaxed text-white/80">{option.dashboardSummary}</p>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>
	</main>
</Layout>
