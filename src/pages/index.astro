---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Centro de Autoprotección - Protocólos">
	<main class="min-h-screen bg-neutral-100 flex flex-col items-center py-12 px-4 selection:bg-orange-200">
		<div class="max-w-md w-full flex flex-col items-center mb-8 text-center">
			
            <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-lg border border-neutral-200 mb-6 relative overflow-hidden p-2">
                <img src="/assets/LOGO-PC-NUEVO-e1754668914257.png" alt="Logo Protección Civil" class="object-contain w-full h-full" onerror="this.src='/assets/safety_shield_icon_1774892711246.png'" />
            </div>

			<h1 class="text-3xl font-extrabold text-neutral-900 tracking-tight leading-tight mb-2">
				Protocolos de Autoprotección
			</h1>
			<p class="text-neutral-500 text-sm max-w-xs mx-auto mb-8 font-medium">
				Seleccione un tema. Dentro de cada folleto podrá cambiar entre los temas Glass y Friendly.
			</p>
            
		</div>

        <div class="w-full max-w-md space-y-4">
            <div class="flex items-center justify-center gap-3 text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-neutral-400 mb-2">
                <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-blue-500"></span>Glass</span>
                <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-yellow-400"></span>Friendly</span>
            </div>

            <a href="/sismos-glass" class="block w-full bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-blue-500 to-yellow-400 opacity-70"></div>
                <div>
                    <p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-neutral-400 mb-2">Tema 1</p>
                    <h2 class="text-lg font-bold text-neutral-900">Sismos y Terremotos</h2>
                    <p class="text-sm text-neutral-500 mt-2">Protocolo inmediato, refugio seguro y acciones posteriores.</p>
                </div>
            </a>

            <a href="/inundaciones-glass" class="block w-full bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-blue-500 to-yellow-400 opacity-70"></div>
                <div>
                    <p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-neutral-400 mb-2">Tema 2</p>
                    <h2 class="text-lg font-bold text-neutral-900">Lluvias e Inundaciones</h2>
                    <p class="text-sm text-neutral-500 mt-2">Prevención, desplazamiento seguro y niveles de alerta.</p>
                </div>
            </a>

            <a href="/orden-publico-glass" class="block w-full bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-blue-500 to-yellow-400 opacity-70"></div>
                <div>
                    <p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-neutral-400 mb-2">Tema 3</p>
                    <h2 class="text-lg font-bold text-neutral-900">Orden Público y Crisis</h2>
                    <p class="text-sm text-neutral-500 mt-2">Refugio doméstico, suministros y coordinación comunitaria.</p>
                </div>
            </a>

            <a href="/otros-riesgos-glass" class="block w-full bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-blue-500 to-yellow-400 opacity-70"></div>
                <div>
                    <p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-neutral-400 mb-2">Tema 4</p>
                    <h2 class="text-lg font-bold text-neutral-900">Riesgos Específicos</h2>
                    <p class="text-sm text-neutral-500 mt-2">Incendios, derrames y otros eventos puntuales de riesgo.</p>
                </div>
            </a>
        </div>
	</main>
</Layout>
