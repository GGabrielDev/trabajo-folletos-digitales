---
import Layout from '../layouts/Layout.astro';
import { ShieldAlert, BookOpen, Layers, CheckCircle } from 'lucide-react';
---

<Layout title="Centro de Autoprotección - Protocólos">
	<main class="min-h-screen bg-neutral-100 flex flex-col items-center py-12 px-4 selection:bg-orange-200">
		<div class="max-w-md w-full flex flex-col items-center mb-8 text-center">
			
            <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-lg border border-neutral-200 mb-6 relative overflow-hidden p-2">
                <img src="/assets/LOGO-PC-NUEVO-e1754668914257.png" alt="Logo Protección Civil" class="object-contain w-full h-full" onerror="this.src='/assets/safety_shield_icon_1774892711246.png'" />
            </div>

			<h1 class="text-3xl font-extrabold text-neutral-900 tracking-tight leading-tight mb-2">
				Protocolos de Autoprotección
			</h1>
			<p class="text-neutral-500 text-sm max-w-xs mx-auto mb-8 font-medium">
				Seleccione el folleto digital y el diseño a revisar.
			</p>
            
		</div>

        <div class="w-full max-w-md space-y-8">
            <!-- Sección Glassmorphism -->
            <section>
                <h3 class="font-bold text-neutral-400 uppercase tracking-widest text-xs mb-3 flex items-center gap-2">
                    <span class="w-4 h-4 rounded bg-blue-500"></span> Estilo Glassmorphism (Premium)
                </h3>
                <ul class="space-y-3">
                    <li>
                        <a href="/sismos-glass" class="block w-full bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                            <div class="absolute right-0 top-0 bottom-0 w-1.5 bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <h2 class="text-md font-bold text-neutral-800">1. Sismos y Terremotos</h2>
                        </a>
                    </li>
                    <li>
                        <a href="/inundaciones-glass" class="block w-full bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                            <div class="absolute right-0 top-0 bottom-0 w-1.5 bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <h2 class="text-md font-bold text-neutral-800">2. Lluvias e Inundaciones</h2>
                        </a>
                    </li>
                    <li>
                        <a href="/orden-publico-glass" class="block w-full bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                            <div class="absolute right-0 top-0 bottom-0 w-1.5 bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <h2 class="text-md font-bold text-neutral-800">3. Orden Público y Crisis</h2>
                        </a>
                    </li>
                    <li>
                        <a href="/otros-riesgos-glass" class="block w-full bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                            <div class="absolute right-0 top-0 bottom-0 w-1.5 bg-blue-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <h2 class="text-md font-bold text-neutral-800">4. Riesgos Específicos</h2>
                        </a>
                    </li>
                </ul>
            </section>

            <!-- Sección Joven y Amigable -->
            <section>
                <h3 class="font-bold text-neutral-400 uppercase tracking-widest text-xs mb-3 flex items-center gap-2">
                    <span class="w-4 h-4 rounded bg-yellow-400"></span> Estilo Joven y Amigable
                </h3>
                <ul class="space-y-3">
                    <li>
                        <a href="/sismos-friendly" class="block w-full bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                            <div class="absolute right-0 top-0 bottom-0 w-1.5 bg-yellow-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <h2 class="text-md font-bold text-neutral-800">1. Sismos y Terremotos</h2>
                        </a>
                    </li>
                    <li>
                        <a href="/inundaciones-friendly" class="block w-full bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                            <div class="absolute right-0 top-0 bottom-0 w-1.5 bg-yellow-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <h2 class="text-md font-bold text-neutral-800">2. Lluvias e Inundaciones</h2>
                        </a>
                    </li>
                    <li>
                        <a href="/orden-publico-friendly" class="block w-full bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                            <div class="absolute right-0 top-0 bottom-0 w-1.5 bg-yellow-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <h2 class="text-md font-bold text-neutral-800">3. Orden Público y Crisis</h2>
                        </a>
                    </li>
                    <li>
                        <a href="/otros-riesgos-friendly" class="block w-full bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition-all border border-neutral-200 group relative overflow-hidden">
                            <div class="absolute right-0 top-0 bottom-0 w-1.5 bg-yellow-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <h2 class="text-md font-bold text-neutral-800">4. Riesgos Específicos</h2>
                        </a>
                    </li>
                </ul>
            </section>
        </div>
	</main>
</Layout>
