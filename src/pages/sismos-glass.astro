---
import Layout from '../layouts/Layout.astro';
import HomeButton from '../components/HomeButton.astro';
import ThemeSwitch from '../components/ThemeSwitch.astro';
import { AlertTriangle, Home, BookOpen, Volume2, ShieldAlert } from 'lucide-react';
---

<Layout title="Autoprotección Sísmica - Glassmorphism">
	<main class="relative min-h-screen bg-[#0f172a] overflow-hidden text-slate-100 font-inter font-light">
		
        <!-- Abstract gradient blobs for glassmorphism effect -->
        <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-blue-600 rounded-full mix-blend-multiply filter blur-[120px] opacity-70 animate-blob"></div>
        <div class="absolute top-[20%] right-[-10%] w-[400px] h-[400px] bg-teal-500 rounded-full mix-blend-multiply filter blur-[120px] opacity-70 animate-blob animation-delay-2000"></div>
        <div class="absolute bottom-[-10%] left-[20%] w-[600px] h-[600px] bg-indigo-600 rounded-full mix-blend-multiply filter blur-[120px] opacity-70 animate-blob animation-delay-4000"></div>

        <div class="relative z-10 p-6 max-w-lg mx-auto min-h-screen flex flex-col justify-start pb-24">
            
            <header class="flex justify-between items-center gap-3 mb-8 glassmorphism-dark rounded-full px-4 py-3">
                <div class="flex items-center gap-3 min-w-0">
                     <div class="w-10 h-10 bg-white/10 rounded-full backdrop-blur-sm flex items-center justify-center border border-white/20 overflow-hidden p-1.5">
                          <img src="/assets/LOGO-PC-NUEVO-e1754668914257.png" alt="Directorate of Civil Protection Logo" class="w-full h-full object-contain" />
                     </div>
                    <ThemeSwitch
                        currentTheme="glass"
                        glassHref="/sismos-glass"
                        friendlyHref="/sismos-friendly"
                        tone="dark"
                    />
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    <div class="hidden text-xs uppercase tracking-widest font-semibold text-blue-300 sm:block">
                        Sismos
                    </div>
                    <HomeButton tone="dark" />
                </div>
            </header>

            <div class="glassmorphism-dark rounded-3xl p-8 mb-6 relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent"></div>
                
                <h1 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-blue-200 to-teal-200 mb-2 mt-4 tracking-tighter">
                    ¡Agáchate, Cúbrete y Agárrate!
                </h1>
                <p class="text-slate-300 text-sm mb-6 leading-relaxed">
                    Protocolo oficial básico de autoprotección ante eventos sísmicos según FUNVISIS.
                </p>

                <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-2xl mb-2 flex items-center justify-center backdrop-blur-md bg-white/5 border border-white/10" style="background-image: url('/assets/earthquake_illustration_1774892678686.png'); background-size: cover; background-position: center;">
                </div>
            </div>

            <h2 class="text-lg font-bold mb-4 ml-2 mt-2 text-white/90">Protocolo Inmediato</h2>

            <div class="space-y-4">
               <div class="glassmorphism-dark rounded-2xl p-5 flex items-start gap-4 transition-all hover:bg-white/10">
                    <div class="bg-blue-500/20 p-3 rounded-xl border border-blue-400/30 text-blue-300">
                        <Home size={24} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1">Permanezca en el sitio</h3>
                        <p class="text-xs text-slate-400">Si está en interiores, quédese adentro. Refúgiese bajo un mueble fuerte (como un escritorio resistente) y agárrese de él hasta que pase el temblor.</p>
                    </div>
               </div>

               <div class="glassmorphism-dark rounded-2xl p-5 flex items-start gap-4 transition-all hover:bg-white/10">
                    <div class="bg-teal-500/20 p-3 rounded-xl border border-teal-400/30 text-teal-300">
                        <AlertTriangle size={24} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1">Lo que NO debe hacer</h3>
                        <p class="text-xs text-slate-400">No use el marco de la puerta. Es falso que protegen. Nunca use los ascensores ni las escaleras durante el sismo.</p>
                    </div>
               </div>

               <div class="glassmorphism-dark rounded-2xl p-5 flex items-start gap-4 transition-all hover:bg-white/10">
                    <div class="bg-indigo-500/20 p-3 rounded-xl border border-indigo-400/30 text-indigo-300">
                        <Volume2 size={24} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1">Información Oficial</h3>
                        <p class="text-xs text-slate-400">Finalizado el movimiento, corte el gas y sintonice estaciones de radio con un dispositivo a baterías. No llame por teléfono celular a menos que sea una verdadera emergencia.</p>
                    </div>
               </div>
            </div>

        </div>
	</main>
</Layout>
