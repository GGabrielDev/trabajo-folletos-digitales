---
import Layout from '../layouts/Layout.astro';
import HomeButton from '../components/HomeButton.astro';
import ThemeSwitch from '../components/ThemeSwitch.astro';
import { Flame, Droplets, BugIcon, TreePine } from 'lucide-react';
---

<Layout title="Riesgos Específicos - Glassmorphism">
	<main class="relative min-h-screen bg-[#0f172a] overflow-hidden text-slate-100 font-inter font-light">
		
        <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-orange-600 rounded-full mix-blend-multiply filter blur-[120px] opacity-70 animate-blob"></div>
        <div class="absolute top-[20%] right-[-10%] w-[400px] h-[400px] bg-red-600 rounded-full mix-blend-multiply filter blur-[120px] opacity-70 animate-blob animation-delay-2000"></div>
        <div class="absolute bottom-[-10%] left-[20%] w-[600px] h-[600px] bg-yellow-600 rounded-full mix-blend-multiply filter blur-[120px] opacity-70 animate-blob animation-delay-4000"></div>

        <div class="relative z-10 p-6 max-w-lg mx-auto min-h-screen flex flex-col justify-start pb-24">
            
            <header class="flex justify-between items-center gap-3 mb-8 glassmorphism-dark rounded-full px-4 py-3">
                <div class="flex items-center gap-3 min-w-0">
                     <div class="w-10 h-10 bg-white/10 rounded-full backdrop-blur-sm flex items-center justify-center border border-white/20 overflow-hidden p-1.5">
                          <img src="/assets/LOGO-PC-NUEVO-e1754668914257.png" alt="Directorate of Civil Protection Logo" class="w-full h-full object-contain" />
                     </div>
                    <ThemeSwitch
                        currentTheme="glass"
                        glassHref="/otros-riesgos-glass"
                        friendlyHref="/otros-riesgos-friendly"
                        tone="dark"
                    />
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    <div class="hidden text-xs uppercase tracking-widest font-semibold text-orange-300 sm:block">
                        Otras Amenazas
                    </div>
                    <HomeButton tone="dark" />
                </div>
            </header>

            <div class="glassmorphism-dark rounded-3xl p-8 mb-6 relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent"></div>
                
                <h1 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-orange-200 to-yellow-200 mb-2 mt-4 tracking-tighter leading-tight">
                    Incendios Forestales y Especiales
                </h1>
                <p class="text-slate-300 text-sm mb-6 leading-relaxed">
                    Manejo de sustancias peligrosas, fuego forestal y protección contra vectores biológicos en Venezuela.
                </p>

                <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-2xl mb-2 flex items-center justify-center backdrop-blur-md bg-white/5 border border-white/10" style="background-image: url('/assets/fire_safety_illustration_1774910229007.png'); background-size: cover; background-position: center;">
                </div>
            </div>

            <h2 class="text-lg font-bold mb-4 ml-2 mt-2 text-white/90">Protocolos</h2>

            <div class="space-y-4">
               <div class="glassmorphism-dark rounded-2xl p-5 flex items-start gap-4 transition-all hover:bg-white/10">
                    <div class="bg-orange-500/20 p-3 rounded-xl border border-orange-400/30 text-orange-300 flex-shrink-0">
                        <Flame size={24} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1">Contingencia Forestal</h3>
                        <p class="text-xs text-slate-400">Mantenga un "espacio defendible" de al menos 9 metros alrededor de la edificación en zonas boscosas. Evacuemos siempre caminando en sentido contrario al viento.</p>
                    </div>
               </div>

               <div class="glassmorphism-dark rounded-2xl p-5 flex items-start gap-4 transition-all hover:bg-white/10">
                    <div class="bg-indigo-500/20 p-3 rounded-xl border border-indigo-400/30 text-indigo-300 flex-shrink-0">
                        <Droplets size={24} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1">Derrame de Hidrocarburos</h3>
                        <p class="text-xs text-slate-400">Evacue el área de inmediato por riesgo inminente de explosión. Absténgase de limpiar directamente, es responsabilidad de los entes especializados.</p>
                    </div>
               </div>

               <div class="glassmorphism-dark rounded-2xl p-5 flex items-start gap-4 transition-all hover:bg-white/10">
                    <div class="bg-yellow-500/20 p-3 rounded-xl border border-yellow-400/30 text-yellow-300 flex-shrink-0">
                        <BugIcon size={24} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg mb-1">Enjambres Peligrosos</h3>
                        <p class="text-xs text-slate-400">NO intente agredir abejas o avispas echando agua o insecticida. Acordone la zona del enjambre y notifique rápidamente a Protección Civil.</p>
                    </div>
               </div>
            </div>

        </div>
	</main>
</Layout>
