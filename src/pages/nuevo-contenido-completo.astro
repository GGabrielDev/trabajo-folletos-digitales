---
import EmergencyHeader from '../components/EmergencyHeader.astro';
import EmergencyTopicSection from '../components/EmergencyTopicSection.astro';
import Layout from '../layouts/Layout.astro';
import { emergencyTopics } from '../data/emergencyTopics';
---

<Layout title="Seguridad y Gestion de Riesgo - Integral">
  <main class="min-h-screen bg-[var(--color-bg-light)]">
    <EmergencyHeader
      title="Seguridad y Gestion de Riesgo"
      subtitle="En caso de emergencia, contactar a los numeros de emergencia: 911 y 0800-7248451"
    />

    <section class="bg-white">
      <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
        <div class="pc-hazard-stripe mb-6 h-2 w-full sm:mb-8"></div>
        <div class="max-w-3xl">
          <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)] sm:text-sm">
            Vista continua
          </p>
          <h2 class="text-2xl font-black text-[var(--color-secondary)] sm:text-3xl">El mismo contenido en una sola lectura</h2>
          <p class="mt-3 text-sm leading-6 text-[var(--color-text-dark)] sm:text-base sm:leading-7">
            Esta version recorre los cuatro temas en un flujo largo, manteniendo la estructura Antes, Durante y Después para leer de corrido.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-[var(--color-bg-light)]">
      <div class="mx-auto max-w-6xl space-y-8 px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
        {emergencyTopics.map((topic, index) => (
          <EmergencyTopicSection topic={topic} index={index} />
        ))}
      </div>
    </section>
  </main>
</Layout>
