---
import Layout from '../layouts/Layout.astro';
import { ChevronLeft, Layers } from 'lucide-react';
import { newInformationItems } from '../data/newInformation';
---

<Layout title="Nueva Información - Vista Integral">
  <main class="min-h-screen bg-[var(--color-bg-light)]">
    <section class="relative overflow-hidden bg-[var(--color-secondary)] text-white">
      <div class="pc-dot-grid absolute inset-0 opacity-70"></div>
      <div class="absolute inset-0" style="background-image: var(--gradient-overlay), url('/assets/a_group_of_people_gathered_around_a_large_map_the.jpg'); background-size: cover; background-position: center;"></div>

      <div class="relative z-10 mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
        <div class="mb-6 flex flex-col gap-4 border-b border-white/15 pb-4 sm:mb-8 lg:flex-row lg:items-center lg:justify-between">
          <div class="flex items-center gap-3 sm:gap-4">
            <div class="h-12 w-12 overflow-hidden rounded-full border-2 border-white/50 bg-white p-1.5 sm:h-16 sm:w-16">
              <img src="/assets/LOGO-PC-NUEVO-e1754668914257.png" alt="Logo Protección Civil" class="h-full w-full object-contain" />
            </div>
            <div>
              <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-white/75 sm:text-sm sm:tracking-[0.2em]">Nueva Información</p>
              <h1 class="text-2xl font-black sm:text-5xl">Vista Todo en Uno</h1>
            </div>
          </div>
          <a href="/" class="inline-flex min-h-11 items-center justify-center gap-1.5 px-4 py-2 border border-white/20 bg-white/5 hover:bg-white/10 text-white text-xs font-bold uppercase tracking-[0.12em] transition-colors self-start lg:self-auto">
            <ChevronLeft size={16} strokeWidth={2.75} />
            <span>Volver al Tablero</span>
          </a>
        </div>

        <div class="max-w-3xl">
          <div class="pc-ribbon mb-5 inline-flex items-center gap-2 px-4 py-2 text-xs font-bold uppercase tracking-[0.14em]">
            <Layers size={14} strokeWidth={2.75} />
            <span>Base inicial preparada</span>
          </div>
          <p class="text-sm leading-6 text-white/85 sm:text-base sm:leading-7">
            Esta vista reúne en una sola página el mismo contenido disponible en la versión organizada por cuatro submenús.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
        <div class="pc-hazard-stripe mb-6 h-2 w-full sm:mb-8"></div>
        <div class="grid gap-6 lg:grid-cols-2">
          {newInformationItems.map((item, index) => (
            <article class="pc-card pc-diagonal pc-hard-shadow relative overflow-hidden p-5 sm:p-6">
              <div class="pc-card-image absolute inset-0" style={`background-image: url('${item.image}'); background-size: cover; background-position: center; opacity: 0.12;`}></div>
              <div class="relative z-10 flex flex-col gap-3">
                <span class="pc-tag pc-tag-primary w-fit">Bloque {index + 1}</span>
                <h2 class="text-lg font-black text-white sm:text-xl">{item.title}</h2>
                <p class="text-sm leading-6 text-white/85">{item.summary}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
