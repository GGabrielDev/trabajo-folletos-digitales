---
import Layout from '../layouts/Layout.astro';
import { CloudRain, Navigation, ShieldCheck } from 'lucide-react';
---

<Layout title="Lluvias e Inundaciones - Amigable">
	<main class="min-h-screen bg-indigo-200 text-indigo-950 font-inter selection:bg-teal-300 selection:text-teal-900 pb-20 relative overflow-hidden">
		
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-teal-400 rounded-full mix-blend-multiply opacity-50 blur-xl"></div>
        <div class="absolute top-40 -left-10 w-32 h-32 bg-cyan-400 rounded-full mix-blend-multiply opacity-50 blur-xl"></div>

        <div class="max-w-md mx-auto min-h-screen flex flex-col justify-start px-6 pt-10 z-10 relative">
            
            <header class="flex justify-between items-center bg-white/70 backdrop-blur-md rounded-full shadow-sm p-2 mb-8 border border-white/50">
                <div class="w-10 h-10 rounded-full bg-teal-500 text-white flex items-center justify-center font-bold text-[0.5rem] shadow-inner ml-1">
                    PC
                </div>
                <h1 class="text-sm font-bold tracking-wide text-indigo-800 mr-4">
                    Clima <span class="bg-cyan-300 text-indigo-900 px-2 py-0.5 rounded-full ml-1 text-xs">Alerta</span>
                </h1>
            </header>

            <div class="bg-white rounded-[2.5rem] p-6 shadow-xl border-4 border-white mb-6 transform rotate-1 hover:-rotate-1 transition-transform duration-300">
                <h2 class="text-3xl font-black text-center text-indigo-600 mb-1 leading-tight tracking-tight">
                    ¿Inundaciones y<br/> Lluvias?
                </h2>
                <div class="w-full aspect-square rounded-3xl mt-4 mb-2 overflow-hidden shadow-inner border-4 border-indigo-100 relative bg-indigo-50 flex items-center justify-center" style="background-image: url('/assets/floods_illustration_1774910201216.png'); background-size: cover; background-position: center;">
                </div>
            </div>

            <section class="space-y-4 pt-4">
                
                <div class="bg-white/80 backdrop-blur rounded-[2rem] p-5 shadow-sm border border-white flex gap-4 items-center">
                    <div class="w-14 h-14 bg-cyan-300 rounded-2xl flex items-center justify-center text-cyan-800 flex-shrink-0 shadow-sm transform -rotate-3">
                        <CloudRain size={28} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 leading-tight">Aléjate del Agua</h3>
                        <p class="text-sm text-slate-600 leading-snug mt-1">
                            ¡Nunca intentes cruzar ríos crecidos! La corriente engaña y puede arrastrar fácilmente.
                        </p>
                    </div>
                </div>

                <div class="bg-white/80 backdrop-blur rounded-[2rem] p-5 shadow-sm border border-white flex gap-4 items-center">
                    <div class="w-14 h-14 bg-teal-400 rounded-2xl flex items-center justify-center text-white flex-shrink-0 shadow-sm transform rotate-6">
                        <Navigation size={28} strokeWidth={2.5}/>
                    </div>
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 leading-tight">Zonas Altas</h3>
                        <p class="text-sm text-slate-600 leading-snug mt-1">
                            Si el agua entra en casa, sube a pisos superiores y apaga urgente la electricidad principal.
                        </p>
                    </div>
                </div>

                <div class="bg-white/80 backdrop-blur rounded-[2rem] p-5 shadow-sm border border-white flex gap-4 items-center">
                   <div class="w-14 h-14 bg-yellow-400 rounded-2xl flex items-center justify-center text-white flex-shrink-0 shadow-sm transform -rotate-2">
                        <ShieldCheck size={28} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 leading-tight">Después de</h3>
                        <p class="text-sm text-slate-600 leading-snug mt-1">
                            Limpia todo muy bien. El agua empozada trae enfermedades e insectos.
                        </p>
                    </div>
                </div>

            </section>

        </div>
	</main>
</Layout>
