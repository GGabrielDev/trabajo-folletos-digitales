---
import Layout from '../layouts/Layout.astro';
import { Home, PackageCheck, Users } from 'lucide-react';
---

<Layout title="Orden Público - Amigable">
	<main class="min-h-screen bg-rose-200 text-rose-950 font-inter selection:bg-orange-300 selection:text-orange-900 pb-20 relative overflow-hidden">
		
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-orange-400 rounded-full mix-blend-multiply opacity-50 blur-xl"></div>
        <div class="absolute top-40 -left-10 w-32 h-32 bg-yellow-400 rounded-full mix-blend-multiply opacity-50 blur-xl"></div>

        <div class="max-w-md mx-auto min-h-screen flex flex-col justify-start px-6 pt-10 z-10 relative">
            
            <header class="flex justify-between items-center bg-white/70 backdrop-blur-md rounded-full shadow-sm p-2 mb-8 border border-white/50">
                <div class="w-10 h-10 rounded-full bg-rose-500 text-white flex items-center justify-center font-bold text-[0.5rem] shadow-inner ml-1">
                    PC
                </div>
                <h1 class="text-sm font-bold tracking-wide text-rose-800 mr-4">
                    Prevención <span class="bg-orange-300 text-rose-900 px-2 py-0.5 rounded-full ml-1 text-xs">Familiar</span>
                </h1>
            </header>

            <div class="bg-white rounded-[2.5rem] p-6 shadow-xl border-4 border-white mb-6 transform -rotate-1 hover:rotate-1 transition-transform duration-300">
                <h2 class="text-3xl font-black text-center text-rose-600 mb-1 leading-tight tracking-tight">
                    Cuidarnos en<br/> Comunidad
                </h2>
                <div class="w-full aspect-square rounded-3xl mt-4 mb-2 overflow-hidden shadow-inner border-4 border-rose-100 relative bg-rose-50 flex items-center justify-center" style="background-image: url('/assets/civil_safety_illustration_1774910214897.png'); background-size: cover; background-position: center;">
                </div>
            </div>

            <section class="space-y-4 pt-4">
                
                <div class="bg-white/80 backdrop-blur rounded-[2rem] p-5 shadow-sm border border-white flex gap-4 items-center">
                    <div class="w-14 h-14 bg-orange-300 rounded-2xl flex items-center justify-center text-orange-900 flex-shrink-0 shadow-sm transform rotate-4">
                        <Home size={28} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 leading-tight">Casita Segura</h3>
                        <p class="text-sm text-slate-600 leading-snug mt-1">
                            Quédate adentro si hay problemas en la calle. Aléjate de las ventanas grandes y de cristal.
                        </p>
                    </div>
                </div>

                <div class="bg-white/80 backdrop-blur rounded-[2rem] p-5 shadow-sm border border-white flex gap-4 items-center">
                    <div class="w-14 h-14 bg-yellow-400 rounded-2xl flex items-center justify-center text-yellow-900 flex-shrink-0 shadow-sm transform -rotate-3">
                        <PackageCheck size={28} strokeWidth={2.5}/>
                    </div>
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 leading-tight">Prepara la Despensa</h3>
                        <p class="text-sm text-slate-600 leading-snug mt-1">
                            Guarda comidita que no se dañe rápido y agüita (3 litros por persona) para no tener que salir.
                        </p>
                    </div>
                </div>

                <div class="bg-white/80 backdrop-blur rounded-[2rem] p-5 shadow-sm border border-white flex gap-4 items-center">
                   <div class="w-14 h-14 bg-rose-400 rounded-2xl flex items-center justify-center text-white flex-shrink-0 shadow-sm transform rotate-2">
                        <Users size={28} />
                    </div>
                    <div>
                        <h3 class="font-bold text-lg text-slate-800 leading-tight">Vecinos Atentos</h3>
                        <p class="text-sm text-slate-600 leading-snug mt-1">
                            Habla con los vecinos que más confías. ¡Entre todos se vigilan y ayudan mucho mejor!
                        </p>
                    </div>
                </div>

            </section>

        </div>
	</main>
</Layout>
