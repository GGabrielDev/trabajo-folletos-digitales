---
import EmergencyHeader from '../components/EmergencyHeader.astro';
import Layout from '../layouts/Layout.astro';
import { emergencyTopics } from '../data/emergencyTopics';
---

<Layout title="Seguridad y Gestion de Riesgo - Submenus">
  <main class="min-h-screen bg-[var(--color-bg-light)]">
    <EmergencyHeader
      title="Seguridad y Gestion de Riesgo"
      subtitle="En caso de emergencia, contactar a los numeros de emergencia: 911 y 0800-7248451"
    />

    <section class="bg-white">
      <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
        <div class="pc-hazard-stripe mb-6 h-2 w-full sm:mb-8"></div>
        <div class="mb-6 max-w-3xl">
          <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)] sm:text-sm">
            Acceso por botones
          </p>
          <h2 class="text-2xl font-black text-[var(--color-secondary)] sm:text-3xl">Cinco submenus, cinco paginas</h2>
          <p class="mt-3 text-sm leading-6 text-[var(--color-text-dark)] sm:text-base sm:leading-7">
            Cada boton abre su propio submenu. Dentro de esos submenus aparece el boton flotante para volver a esta pantalla.
          </p>
        </div>

        <div class="space-y-3 sm:space-y-4">
          {emergencyTopics.map((topic) => (
            <a
              href={`/nuevo-contenido-submenus/${topic.id}`}
              class="group relative mx-auto block w-full max-w-5xl overflow-hidden border border-black/10 bg-[var(--color-secondary)] text-white shadow-[4px_4px_0_0_var(--color-secondary)] transition-transform hover:-translate-y-1"
            >
              <div
                class="absolute inset-0 bg-no-repeat opacity-90 transition-transform duration-300 group-hover:scale-[1.04]"
                style={`background-image: var(--gradient-overlay), url('${topic.image}'); background-size: cover; background-position: center;`}
              ></div>
              <div class="relative z-10 flex items-center gap-3 px-4 py-4 sm:px-5 sm:py-5">
                <span class="text-2xl sm:text-3xl">{topic.emoji}</span>
                <h3 class="text-base font-black leading-tight sm:text-lg">{topic.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
