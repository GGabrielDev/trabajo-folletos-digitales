---
import type { EmergencyTopic } from '../data/emergencyTopics';

interface Props {
  topic: EmergencyTopic;
  index: number;
}

const { topic, index } = Astro.props;
---

<section id={topic.id} class="scroll-mt-28">
  <article class="pc-card pc-hard-shadow-light overflow-hidden border border-black/10 bg-white">
    <div
      class="relative flex min-h-[16rem] items-end overflow-hidden bg-[var(--color-secondary)] text-white sm:min-h-[18rem]"
      style={`background-image: var(--gradient-overlay), url('${topic.image}'); background-size: cover; background-position: center;`}
    >
      <div class="pc-dot-grid absolute inset-0 opacity-50"></div>
      <div
        class="absolute inset-0 bg-no-repeat opacity-10"
        style="background-image: url('/assets/LOGO-PC-NUEVO-e1754668914257.png'); background-size: min(42vw, 18rem); background-position: right -1rem top -1rem;"
      ></div>
      <div class="relative z-10 flex w-full flex-col gap-4 px-4 py-5 sm:px-6 sm:py-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <div class="mb-3 flex flex-wrap items-center gap-2">
            <span class="pc-tag pc-tag-primary">Tema {index + 1}</span>
            <span class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-white/75 sm:text-xs">
              {topic.emoji} {topic.title}
            </span>
          </div>
          <h2 class="text-2xl font-black leading-tight sm:text-4xl">{topic.title}</h2>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-white/88 sm:text-base sm:leading-7">
            {topic.summary}
          </p>
        </div>

        <div class="pc-ribbon max-w-xl px-4 py-3 text-xs font-bold uppercase tracking-[0.12em] sm:text-sm">
          {topic.ribbon}
        </div>
      </div>
    </div>

    <div class="space-y-8 px-4 py-5 sm:px-6 sm:py-6">
      <div class="grid gap-4 lg:grid-cols-3">
        {topic.phases.map((phase) => (
          <section class="pc-brutalist-card flex h-full flex-col overflow-hidden bg-[var(--color-bg-light)] p-4 sm:p-5">
            <div class="mb-4 flex items-center gap-3">
              <div class="inline-flex h-11 w-11 shrink-0 items-center justify-center bg-[var(--color-primary)] text-xl text-white">
                {phase.label === 'Antes' ? '1' : phase.label === 'Durante' ? '2' : '3'}
              </div>
              <div>
                <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-[var(--color-primary)]">
                  {phase.label}
                </p>
                <h3 class="text-lg font-black leading-tight text-[var(--color-secondary)]">{phase.lead}</h3>
              </div>
            </div>
            <ul class="flex flex-1 flex-col gap-3">
              {phase.points.map((point) => (
                <li class="pc-timeline-item text-sm leading-6 text-[var(--color-text-dark)]">
                  <span class="pc-timeline-dot"></span>
                  {point}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>

      <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
        <section class="space-y-4">
          <div>
            <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)] sm:text-sm">
              {topic.mapTitle}
            </p>
            <h3 class="text-2xl font-black text-[var(--color-secondary)]">Mapa mental de respuesta</h3>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            {topic.mapNodes.map((node, nodeIndex) => (
              <article class="pc-card pc-hard-shadow-light flex h-full flex-col gap-2 bg-white p-4">
                <div class="flex items-center gap-3">
                  <span class="inline-flex h-10 w-10 items-center justify-center bg-[var(--color-secondary)] text-sm font-black text-white">
                    0{nodeIndex + 1}
                  </span>
                  <h4 class="text-base font-black uppercase tracking-[0.06em] text-[var(--color-secondary)]">
                    {node.label}
                  </h4>
                </div>
                <p class="text-sm leading-6 text-[var(--color-text-dark)]">{node.detail}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="space-y-4">
          <div>
            <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)] sm:text-sm">
              {topic.infographicTitle}
            </p>
            <h3 class="text-2xl font-black text-[var(--color-secondary)]">Infografía en claves</h3>
          </div>

          <div class="grid gap-3">
            {topic.infographicItems.map((item) => (
              <article class="pc-card pc-hard-shadow-light flex items-start gap-4 bg-[var(--color-secondary)] p-4 text-white">
                <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center bg-[var(--color-primary)] text-xl font-black text-white">
                  !
                </div>
                <div>
                  <h4 class="text-base font-black uppercase tracking-[0.06em] text-white">{item.label}</h4>
                  <p class="mt-1 text-sm leading-6 text-white/85">{item.detail}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>

      <div class="pc-ribbon flex flex-col gap-2 px-4 py-3 text-xs font-bold uppercase tracking-[0.12em] sm:flex-row sm:items-center sm:justify-between sm:text-sm">
        <span>Emergencias: 911</span>
        <span>Protección Civil: 0800-7248451</span>
        <span>{topic.footer}</span>
      </div>
    </div>
  </article>
</section>
