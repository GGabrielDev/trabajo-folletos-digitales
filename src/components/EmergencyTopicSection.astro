---
import type { EmergencyTopic } from '../data/emergencyTopics';
import { ChevronLeft } from 'lucide-react';
import SismosInteractiveInfographic from './SismosInteractiveInfographic.astro';

interface Props {
  topic: EmergencyTopic;
  index: number;
  showFloatingBackButton?: boolean;
  backHref?: string;
}

const { topic, index, showFloatingBackButton = false, backHref = '/nuevo-contenido-submenus' } = Astro.props;
---

<section id={topic.id} class="scroll-mt-28">
  {showFloatingBackButton && (
    <a
      href={backHref}
      class="fixed bottom-4 right-4 z-50 inline-flex min-h-11 items-center justify-center gap-1.5 border border-white/10 bg-[var(--color-secondary)] px-3 py-2 text-[0.68rem] font-bold uppercase tracking-[0.12em] text-white shadow-[4px_4px_0px_var(--color-secondary)] transition-transform hover:-translate-y-1 sm:bottom-6 sm:right-6 sm:text-[0.72rem]"
    >
      <ChevronLeft size={14} strokeWidth={2.75} />
      <span>Volver</span>
    </a>
  )}
  {/* Full Width Content Header Section */}
  <div
    class="relative overflow-hidden bg-[var(--color-secondary)] text-white"
    style={`background-image: var(--gradient-overlay), url('${topic.image}'); background-size: cover; background-position: center;`}
  >
    <div class="pc-dot-grid absolute inset-0 opacity-50"></div>
    <div
      class="absolute inset-0 bg-no-repeat opacity-10"
      style="background-image: url('/assets/LOGO-PC-NUEVO-e1754668914257.png'); background-size: min(42vw, 18rem); background-position: right -1rem top -1rem;"
    ></div>
    <div class="relative z-10 mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div class="max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="pc-tag pc-tag-primary">Tema {index + 1}</span>
          <span class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-white/75 sm:text-xs">
            {topic.emoji} {topic.title}
          </span>
        </div>
        <h2 class="text-2xl font-black leading-tight sm:text-4xl">{topic.title}</h2>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-white/88 sm:text-base sm:leading-7">
          {topic.summary}
        </p>
      </div>

      <div class="pc-ribbon flex flex-col gap-1 max-w-xl px-4 py-3 text-xs font-bold uppercase tracking-[0.12em] sm:text-sm">
        <span>Emergencias: 911</span>
        <span>Protección Civil: 0800-7248451</span>
      </div>
    </div>
  </div>

  {/* Regular Page Content Container */}
  <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <article class="pc-card pc-hard-shadow-light overflow-hidden border border-black/10 bg-white">
      <div class="space-y-8 px-4 py-5 sm:px-6 sm:py-6">
      <div class="grid gap-4 lg:grid-cols-3">
        {topic.phases.map((phase) => (
          <section class="pc-brutalist-card relative flex h-full flex-col overflow-hidden bg-white p-4 text-[var(--color-text-dark)] sm:p-5">
            <div class="relative z-10 mb-4 flex items-center gap-3">
              <div class="inline-flex h-11 w-11 shrink-0 items-center justify-center bg-[var(--color-primary)] text-xl text-white">
                {phase.label === 'Antes' ? '1' : phase.label === 'Durante' ? '2' : '3'}
              </div>
              <div>
                <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-[var(--color-primary)]">
                  {phase.label}
                </p>
                <h3 class="text-lg font-black leading-tight text-[var(--color-secondary)]">{phase.lead}</h3>
              </div>
            </div>
            <ol class="relative z-10 flex flex-1 flex-col gap-3 list-none">
              {phase.points.map((point, ptIndex) => (
                <li class="relative pl-7 text-sm leading-6 text-[var(--color-text-dark)]">
                  <span class="absolute left-0 top-1 flex h-5 w-5 items-center justify-center rounded-full bg-[var(--color-primary)] text-[10px] font-black text-white">
                    {ptIndex + 1}
                  </span>
                  {point}
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>

      {topic.id === 'sismos' ? (
        <SismosInteractiveInfographic />
      ) : (
        topic.infographicImage && (
          <div class="pc-brutalist-card relative overflow-hidden border border-black/10 bg-white p-4 sm:p-6 flex flex-col items-center">
            <div class="mb-5 text-center">
              <p class="mb-1 text-[0.72rem] font-bold uppercase tracking-[0.18em] text-[var(--color-primary)]">
                Material Visual de Autoprotección
              </p>
              <h3 class="text-xl font-black text-[var(--color-secondary)] sm:text-2xl">Guía Visual de Actuación</h3>
            </div>
            <div class="relative group max-w-2xl w-full overflow-hidden rounded border border-black/10 shadow-sm bg-neutral-50 p-2 sm:p-4">
              <img 
                src={topic.infographicImage} 
                alt={`Infografía de Autoprotección - ${topic.title}`} 
                class="w-full h-auto transition-all duration-300 group-hover:scale-[1.01]" 
              />
            </div>
          </div>
        )
      )}

      <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
        <section class="space-y-4">
          <div>
            <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)] sm:text-sm">
              {topic.mapTitle}
            </p>
            <h3 class="text-2xl font-black text-[var(--color-secondary)]">Puntos clave</h3>
          </div>

          {topic.visualSteps ? (
            <div class="relative border-l-2 border-dashed border-[var(--color-primary)]/45 pl-6 ml-3 space-y-6 py-2">
              {topic.visualSteps.map((vStep, vIndex) => (
                <div class="relative flex flex-col gap-4 items-start group">
                  {/* Step Number Badge */}
                  <span class="absolute -left-[35px] top-1.5 flex h-6 w-6 items-center justify-center rounded-full bg-[var(--color-primary)] text-[10px] font-black text-white border border-white shadow-sm z-10">
                    {vStep.step}
                  </span>
                  
                  {/* Step Card */}
                  <div class="pc-card pc-hard-shadow-light w-full bg-white p-3.5 flex gap-4 items-center border border-black/10 hover:translate-x-1 transition-transform duration-300">
                    <div class="h-16 w-16 shrink-0 rounded bg-neutral-50 p-1.5 border border-neutral-100 flex items-center justify-center overflow-hidden">
                      <img src={vStep.image} alt={vStep.title} class="max-h-full max-w-full object-contain" />
                    </div>
                    <div>
                      <h4 class="text-sm font-black uppercase tracking-[0.06em] text-[var(--color-secondary)]">{vStep.title}</h4>
                      <p class="text-[0.8rem] text-neutral-600 mt-1 leading-relaxed">{vStep.detail}</p>
                    </div>
                  </div>
                  
                  {/* Arrow to Next Step */}
                  {vIndex < topic.visualSteps.length - 1 && (
                    <div class="absolute -left-[30px] bottom-[-22px] text-[var(--color-primary)] pointer-events-none z-10">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <polyline points="19 12 12 19 5 12"></polyline>
                      </svg>
                    </div>
                  )}
                </div>
              ))}
            </div>
          ) : (
            <div class="grid gap-3 sm:grid-cols-2">
              {topic.mapNodes.map((node, nodeIndex) => (
                <article class="pc-card pc-hard-shadow-light flex h-full flex-col gap-2 bg-white p-4">
                  <div class="flex items-center gap-3">
                    <span class="inline-flex h-10 w-10 items-center justify-center bg-[var(--color-secondary)] text-sm font-black text-white">
                      0{nodeIndex + 1}
                    </span>
                    <h4 class="text-base font-black uppercase tracking-[0.06em] text-[var(--color-secondary)]">
                      {node.label}
                    </h4>
                  </div>
                  <p class="text-sm leading-6 text-[var(--color-text-dark)]">{node.detail}</p>
                </article>
              ))}
            </div>
          )}
        </section>

        <section class="space-y-4">
          <div>
            <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)] sm:text-sm">
              {topic.infographicTitle}
            </p>
            <h3 class="text-2xl font-black text-[var(--color-secondary)]">Acciones clave</h3>
          </div>

          <div class="grid gap-3">
            {topic.infographicItems.map((item) => (
              <article class="pc-card pc-hard-shadow-light flex items-start gap-4 bg-[var(--color-secondary)] p-4 text-white">
                <div class="inline-flex h-12 w-12 shrink-0 items-center justify-center bg-[var(--color-primary)] text-xl font-black text-white">
                  !
                </div>
                <div>
                  <h4 class="text-base font-black uppercase tracking-[0.06em] text-white">{item.label}</h4>
                  <p class="mt-1 text-sm leading-6 text-white/85">{item.detail}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>

      <div class="pc-ribbon flex flex-col gap-2 px-4 py-3 text-xs font-bold uppercase tracking-[0.12em] sm:flex-row sm:items-center sm:justify-between sm:text-sm">
        <span>{topic.ribbon}</span>
        <span>{topic.footer}</span>
      </div>
      </div>
    </article>
  </div>
</section>
