---
interface Props {
  currentTheme: 'glass' | 'friendly';
  glassHref: string;
  friendlyHref: string;
  tone?: 'dark' | 'light';
}

const {
  currentTheme,
  glassHref,
  friendlyHref,
  tone = 'light',
} = Astro.props;

const shellClass =
  tone === 'dark'
    ? 'bg-white/10 border border-white/15 text-slate-200'
    : 'bg-white/70 border border-white/60 text-slate-700';

const activeClass =
  tone === 'dark'
    ? 'bg-white text-slate-900 shadow-sm'
    : 'bg-slate-900 text-white shadow-sm';

const inactiveClass =
  tone === 'dark'
    ? 'text-slate-300 hover:bg-white/10'
    : 'text-slate-600 hover:bg-slate-900/8';
---

<nav
  aria-label="Selector de tema"
  class:list={[
    'inline-flex items-center gap-1 rounded-full p-1 text-[0.65rem] font-semibold',
    shellClass,
  ]}
>
  <a
    href={glassHref}
    aria-current={currentTheme === 'glass' ? 'page' : undefined}
    class:list={[
      'rounded-full px-3 py-1.5 transition-colors',
      currentTheme === 'glass' ? activeClass : inactiveClass,
    ]}
  >
    Glass
  </a>
  <a
    href={friendlyHref}
    aria-current={currentTheme === 'friendly' ? 'page' : undefined}
    class:list={[
      'rounded-full px-3 py-1.5 transition-colors',
      currentTheme === 'friendly' ? activeClass : inactiveClass,
    ]}
  >
    Friendly
  </a>
</nav>
