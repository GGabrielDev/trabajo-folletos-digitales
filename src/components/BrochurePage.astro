---
import {
  AlertTriangle,
  BugIcon,
  Droplets,
  Flame,
  Home as HomeIcon,
  Navigation,
  PackageCheck,
  Radio,
  ShieldAlert,
  Users,
  Waves,
  Zap,
} from 'lucide-react';
import type { Brochure, BrochureMode } from '../data/brochures';
import Layout from '../layouts/Layout.astro';
import HomeButton from './HomeButton.astro';
import ModeSwitch from './ModeSwitch.astro';
import StyleSwitch from './StyleSwitch.astro';

interface Props {
  brochure: Brochure;
  mode: BrochureMode;
  styleVariant?: 'default' | 'rounded-glass' | 'timeline-step';
}

const { brochure, mode, styleVariant: propStyleVariant } = Astro.props;
const variant = brochure[mode];
const isDark = mode === 'dark';
const styleVariant = propStyleVariant || brochure.styleVariant || 'default';
const isGlass = styleVariant === 'rounded-glass';
const isTimeline = styleVariant === 'timeline-step';

const isSchool = ['brigadas-escolares', 'plan-escolar-pegir', 'evacuacion-simulacros', 'senales-seguridad'].includes(brochure.slug);
const darkHref = isSchool ? `/${brochure.slug}-${styleVariant}-dark` : brochure.darkHref;
const lightHref = isSchool ? `/${brochure.slug}-${styleVariant}-light` : brochure.lightHref;

const alertCardClass = isGlass
  ? (isDark ? 'pc-rounded border border-white/10 bg-white/5 backdrop-blur-sm shadow-none' : 'pc-rounded border border-black/10 bg-white/40 backdrop-blur-sm shadow-none')
  : isTimeline
    ? (isDark ? 'pc-brutalist-card bg-amber-950/20 text-white border-white' : 'pc-brutalist-card bg-slate-50 text-[var(--color-secondary)] border-black')
    : (isDark ? 'pc-card pc-hard-shadow-light bg-[var(--color-bg-dark)] border border-white/10' : 'pc-card pc-hard-shadow-light bg-[var(--color-bg-light)] border border-black/10');

const alertTextClass = isDark ? 'text-white/85' : 'text-[var(--color-text-dark)]';

const cardImages = [
  '/assets/rescue_team_orange.png',
  '/assets/firefighters_rescue.png',
  '/assets/paramedics_first_aid.png'
];

const iconMap = {
  shelter: ShieldAlert,
  warning: AlertTriangle,
  radio: Radio,
  water: Waves,
  electric: Zap,
  route: Navigation,
  home: HomeIcon,
  supply: PackageCheck,
  community: Users,
  fire: Flame,
  spill: Droplets,
  swarm: BugIcon,
} as const;

const levelClasses = {
  green: 'bg-emerald-600 text-white',
  yellow: 'bg-[var(--color-tertiary)] text-[var(--color-secondary)]',
  red: 'bg-red-700 text-white',
} as const;
---

<Layout title={`${brochure.topicLabel} - ${isDark ? 'Oscuro' : 'Claro'}`} mode={mode}>
  <main
    class:list={[
      'min-h-screen transition-colors duration-200',
      isDark
        ? 'bg-[var(--color-bg-dark)] text-[var(--color-text-light)]'
        : 'bg-[var(--color-bg-light)] text-[var(--color-text-dark)]',
    ]}
  >
    <div class="pc-ribbon flex items-center justify-center px-3 py-2 text-center text-[0.62rem] font-bold uppercase tracking-[0.12em] sm:px-4 sm:py-3 sm:text-[0.72rem] sm:tracking-[0.14em]">
      <AlertTriangle size={14} strokeWidth={2.75} class="mr-2 shrink-0" />
      <span>{variant.ribbon}</span>
      <AlertTriangle size={14} strokeWidth={2.75} class="ml-2 shrink-0" />
    </div>

    <section class="relative overflow-hidden">
      <div class="pc-dot-grid absolute inset-0 opacity-70"></div>
      <div class="absolute inset-0 bg-[var(--color-secondary)]"></div>
      <div class:list={['absolute inset-0', isDark ? 'opacity-90' : 'opacity-80']} style={`background-image: ${isGlass ? 'var(--gradient-overlay-cyan)' : 'var(--gradient-overlay)'}, url('${brochure.image}'); background-size: cover; background-position: center;`}></div>

      <div class="relative z-10 mx-auto flex min-h-[30rem] max-w-6xl flex-col px-4 py-5 sm:min-h-[36rem] sm:px-6 sm:py-6 lg:px-8">
        <header class="mb-6 flex flex-col gap-4 border-b border-white/15 pb-4 sm:mb-8">
          <div class="flex w-full items-center justify-between gap-3">
            <div class="flex items-center gap-3">
              <div class="h-11 w-11 shrink-0 overflow-hidden rounded-full border-2 border-white/50 bg-white p-1 sm:h-14 sm:w-14 sm:p-1.5">
                <img src="/assets/LOGO-PC-NUEVO-e1754668914257.png" alt="Logo Protección Civil" class="h-full w-full object-contain" />
              </div>
              <ModeSwitch currentMode={mode} darkHref={darkHref} lightHref={lightHref} />
            </div>

            <div class="flex items-center gap-3 shrink-0">
              {isSchool && (
                <div class="hidden md:block">
                  <StyleSwitch currentStyle={styleVariant} slug={brochure.slug} mode={mode} />
                </div>
              )}
              <HomeButton tone="dark" />
            </div>
          </div>

          {isSchool && (
            <div class="block md:hidden w-full">
              <StyleSwitch currentStyle={styleVariant} slug={brochure.slug} mode={mode} />
            </div>
          )}
        </header>

        <div class="grid flex-1 items-end gap-6 sm:gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(20rem,24rem)]">
          <div class="max-w-3xl">
            <p class="mb-3 text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-white/75 sm:mb-4 sm:text-sm sm:tracking-[0.22em]">{brochure.topicNumber}</p>
            <h1 class="mb-4 max-w-4xl text-3xl font-black text-white sm:text-5xl lg:text-6xl">{variant.title}</h1>
            <p class="max-w-2xl text-sm leading-6 text-white/85 sm:text-base sm:leading-7 lg:text-lg">{variant.summary}</p>
          </div>

          <aside class:list={[
            'relative min-h-[14rem] overflow-hidden sm:min-h-[18rem]',
            isGlass ? 'pc-rounded pc-glass-dark border border-white/10 shadow-none' : '',
            isTimeline ? 'pc-brutalist-card' : '',
            (!isGlass && !isTimeline) ? 'pc-card pc-diagonal pc-hard-shadow' : ''
          ]}>
            <div class="pc-card-image absolute inset-0" style={`background-image: url('${brochure.image}'); background-size: cover; background-position: center;`}></div>
            <div class="relative z-10 flex h-full flex-col justify-end p-4 sm:p-6">
              <span class="pc-tag pc-tag-primary mb-3 w-fit">{brochure.badge}</span>
              <h2 class="text-xl font-black text-white sm:text-2xl">{brochure.topicLabel}</h2>
              <p class="mt-3 text-sm leading-6 text-white/85">{brochure.dashboardSummary}</p>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class:list={['relative', isDark ? 'bg-[var(--color-secondary)]' : 'bg-white']}>
      <div class="pc-watermark mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8">
        <div class="pc-hazard-stripe mb-6 h-2 w-full sm:mb-8"></div>
        <div class="mb-6 flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center sm:gap-4">
          <div>
            <p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)] sm:text-sm sm:tracking-[0.18em]">{brochure.badge}</p>
            <h2 class:list={['text-2xl font-black sm:text-3xl', isDark ? 'text-white' : 'text-[var(--color-secondary)]']}>Acciones prioritarias</h2>
          </div>
        </div>

        {isTimeline ? (
          <div class="grid gap-8 lg:grid-cols-3">
            {variant.cards.map((card, idx) => {
              const Icon = iconMap[card.icon];
              const cardImage = cardImages[idx % cardImages.length];

              if (card.icon === 'route') {
                const phases = card.description.split(/\d+\.\s*/).filter(Boolean);
                return (
                  <article class:list={[
                    'pc-brutalist-card p-5 sm:p-6 flex flex-col h-full relative overflow-hidden',
                    isDark ? 'bg-amber-950/20 text-white border-white' : 'bg-orange-50/50 text-[var(--color-secondary)] border-black'
                  ]}>
                    {cardImage && (
                      <div class="absolute inset-0 opacity-[0.06] pointer-events-none">
                        <img src={cardImage} alt="" class="h-full w-full object-cover" />
                      </div>
                    )}
                    <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-[var(--color-primary)] text-white rounded-sm sm:mb-5 relative z-10">
                      <Icon size={26} strokeWidth={2.75} />
                    </div>
                    <h3 class="mb-5 text-xl font-black relative z-10">{card.title}</h3>
                    
                    <div class="flex-1 flex flex-col gap-4 mt-2 relative z-10">
                      {phases.map((phase, phaseIdx) => {
                        const parts = phase.split(/[\(\)]/).filter(Boolean);
                        const title = parts[0]?.trim();
                        const desc = parts[1]?.trim();
                        return (
                          <div class="pc-timeline-item">
                            <div class="pc-timeline-dot"></div>
                            <h4 class="text-xs font-bold uppercase tracking-wide text-[var(--color-primary)]">
                              Paso {phaseIdx + 1}: {title}
                            </h4>
                            {desc && <p class="text-xs mt-0.5 opacity-80 leading-relaxed">{desc}</p>}
                          </div>
                        );
                      })}
                    </div>
                  </article>
                );
              }

              if (card.icon === 'warning') {
                const rules = [
                  { text: 'No Corro', color: 'bg-red-600 text-white', desc: 'Evita tropezones y amontonamiento en pasillos o escaleras.' },
                  { text: 'No Grito', color: 'bg-amber-500 text-[var(--color-secondary)]', desc: 'Permite escuchar con claridad las instrucciones de los guías.' },
                  { text: 'No Empujo', color: 'bg-orange-500 text-white', desc: 'Mantiene la fila ordenada y fluida para evacuar con rapidez.' }
                ];
                return (
                  <article class:list={[
                    'pc-brutalist-card p-5 sm:p-6 flex flex-col h-full relative overflow-hidden',
                    isDark ? 'bg-amber-950/20 text-white border-white' : 'bg-amber-50/50 text-[var(--color-secondary)] border-black'
                  ]}>
                    {cardImage && (
                      <div class="absolute inset-0 opacity-[0.06] pointer-events-none">
                        <img src={cardImage} alt="" class="h-full w-full object-cover" />
                      </div>
                    )}
                    <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-[var(--color-primary)] text-white rounded-sm sm:mb-5 relative z-10">
                      <Icon size={26} strokeWidth={2.75} />
                    </div>
                    <h3 class="mb-5 text-xl font-black relative z-10">{card.title}</h3>
                    
                    <div class="flex-1 flex flex-col gap-3 relative z-10">
                      {rules.map((rule) => (
                        <div class="flex flex-col gap-1 p-3 border border-black/10 dark:border-white/10 rounded-sm bg-white/5">
                          <div class:list={['pc-rule-badge w-fit text-[0.68rem] py-1 px-2.5', rule.color]}>
                            {rule.text}
                          </div>
                          <p class="text-xs leading-relaxed opacity-85 mt-1">{rule.desc}</p>
                        </div>
                      ))}
                    </div>
                  </article>
                );
              }

              return (
                <article class:list={[
                  'pc-brutalist-card p-5 sm:p-6 h-full flex flex-col relative overflow-hidden',
                  isDark ? 'bg-amber-950/20 text-white border-white' : 'bg-slate-50 text-[var(--color-secondary)] border-black'
                ]}>
                  {cardImage && (
                    <div class="absolute inset-0 opacity-[0.06] pointer-events-none">
                      <img src={cardImage} alt="" class="h-full w-full object-cover" />
                    </div>
                  )}
                  <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-[var(--color-primary)] text-white rounded-sm sm:mb-5 relative z-10">
                    <Icon size={26} strokeWidth={2.75} />
                  </div>
                  <h3 class="mb-3 text-lg font-black sm:text-xl relative z-10">{card.title}</h3>
                  <p class="text-sm leading-6 opacity-82 flex-1 relative z-10">{card.description}</p>
                </article>
              );
            })}
          </div>
        ) : isGlass ? (
          <div class="grid gap-6 lg:grid-cols-3">
            {variant.cards.map((card, idx) => {
              const Icon = iconMap[card.icon];
              const cardImage = cardImages[idx % cardImages.length];

              return (
                <article class:list={[
                  'pc-rounded p-5 sm:p-6 flex flex-col h-full pc-shadow-glow-cyan transition-all hover:scale-[1.02] border relative overflow-hidden',
                  isDark 
                    ? 'pc-glass-dark text-white border-white/10' 
                    : 'pc-glass-light text-[var(--color-secondary)] border-black/10'
                ]}>
                  {cardImage && (
                    <div class="absolute inset-0 opacity-[0.09] pointer-events-none">
                      <img src={cardImage} alt="" class="h-full w-full object-cover" />
                    </div>
                  )}
                  <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-[var(--color-primary)] text-white rounded-full sm:mb-5 sm:h-14 sm:w-14 relative z-10">
                    <Icon size={26} strokeWidth={2.75} />
                  </div>
                  <h3 class="mb-3 text-lg font-black sm:text-xl relative z-10">{card.title}</h3>
                  <p class="text-sm leading-6 opacity-85 flex-1 relative z-10">{card.description}</p>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="grid gap-6 lg:grid-cols-3">
            {variant.cards.map((card, idx) => {
              const Icon = iconMap[card.icon];
              const cardImage = cardImages[idx % cardImages.length];

              return (
                <article class:list={[
                  'pc-card pc-hard-shadow-light pc-diagonal relative overflow-hidden p-5 sm:p-6',
                  isDark ? 'pc-surface-dark pc-outline-panel' : 'pc-surface-light pc-outline-panel-light',
                ]}>
                  {cardImage && (
                    <div class="absolute inset-0 opacity-[0.09] pointer-events-none">
                      <img src={cardImage} alt="" class="h-full w-full object-cover" />
                    </div>
                  )}
                  <div class="mb-4 inline-flex h-12 w-12 items-center justify-center bg-[var(--color-primary)] text-white sm:mb-5 sm:h-14 sm:w-14 relative z-10">
                    <Icon size={26} strokeWidth={2.75} />
                  </div>
                  <h3 class:list={['mb-3 text-lg font-black sm:text-xl relative z-10', isDark ? 'text-white' : 'text-[var(--color-secondary)]']}>{card.title}</h3>
                  <p class:list={['text-sm leading-6', isDark ? 'text-white/82' : 'text-[var(--color-text-dark)]/82']}>{card.description}</p>
                </article>
              );
            })}
          </div>
        )}

        {variant.alertLevels && (
          <div class="mt-8 sm:mt-10 animate-[fadeIn_0.5s_ease-out]">
            <h3 class:list={['mb-4 text-xl font-black sm:text-2xl', isDark ? 'text-white' : 'text-[var(--color-secondary)]']}>Niveles de alerta</h3>
            <div class="grid gap-4 md:grid-cols-3">
              {variant.alertLevels.map((level) => (
                <div class:list={[
                  'p-4 sm:p-5',
                  alertCardClass
                ]}>
                  <div class:list={['mb-3 inline-flex px-3 py-2 text-xs font-bold uppercase tracking-[0.12em]', isGlass ? 'rounded-md' : '', levelClasses[level.tone]]}>
                    {level.label}
                  </div>
                  <p class:list={['text-sm leading-6', alertTextClass]}>{level.description}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        {variant.footer && (
          <div class:list={[
            'mt-8 border-l-[8px] border-[var(--color-primary)] p-5 sm:mt-10 sm:p-6',
            isGlass ? 'pc-rounded border border-black/5 dark:border-white/5 bg-white/5 backdrop-blur-sm shadow-none' : 'pc-hard-shadow border border-black/10',
            isDark ? 'bg-[var(--color-bg-dark)] text-white border-white/10' : 'bg-[var(--color-bg-light)] text-[var(--color-secondary)] border-black/10',
          ]}>
            <p class="text-sm font-medium uppercase tracking-[0.14em] text-[var(--color-primary)]">Nota operativa</p>
            <p class:list={['mt-3 max-w-3xl text-sm leading-6', isDark ? 'text-white/84' : 'text-[var(--color-text-dark)]/84']}>{variant.footer}</p>
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>
