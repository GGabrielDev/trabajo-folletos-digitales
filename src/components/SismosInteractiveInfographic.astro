---
import { AlertTriangle, Home, School, Compass, HelpCircle, CheckCircle, Footprints, ArrowUpDown, Grid, Boxes, PhoneOff } from 'lucide-react';
---

<div class="pc-brutalist-card overflow-hidden border border-black/10 bg-white dark:bg-[#0d1628] dark:border-white/10 p-4 sm:p-6 md:p-8 flex flex-col gap-8 shadow-sm">
  {/* Header Section */}
  <div class="text-center space-y-2 border-b border-dashed border-black/10 dark:border-white/10 pb-6 relative">
    <div class="pc-hazard-stripe h-1.5 w-full absolute top-0 left-0 -mt-6 sm:-mt-8 rounded-t"></div>
    <div class="inline-flex items-center justify-center bg-[var(--color-primary)] text-white px-3 py-1 text-[0.65rem] font-bold uppercase tracking-wider rounded sm:text-xs">
      Guía de Autoprotección
    </div>
    <h3 class="text-2xl font-black text-[var(--color-secondary)] dark:text-white sm:text-3xl">Protocolo de Emergencia Sísmica</h3>
    <p class="text-xs sm:text-sm text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto">
      Instrucciones oficiales de autoprotección basadas en el aula sísmica. Reaccione de forma segura, rápida y ordenada.
    </p>
  </div>

  {/* Row 1: The 3 Main Steps (Agachate, Cubrete, Sujetate) */}
  <div class="space-y-4">
    <div class="flex items-center gap-2 text-[var(--color-secondary)] dark:text-white border-b border-neutral-100 dark:border-neutral-800 pb-2">
      <span class="text-lg">✊</span>
      <h4 class="text-sm sm:text-base font-black uppercase tracking-wider">Pasos Fundamentales de Autoprotección</h4>
    </div>
    
    <div class="grid gap-6 md:grid-cols-3 relative">
      {/* Step 1: Agachate */}
      <div class="border-2 border-cyan-500/20 dark:border-cyan-500/10 rounded-xl p-4 flex flex-col items-center bg-cyan-50/5 dark:bg-cyan-950/5 hover:border-cyan-500 transition-all duration-300 relative group">
        <span class="absolute top-3 left-3 bg-cyan-600 text-white font-black text-xs w-6 h-6 flex items-center justify-center rounded-full shadow-sm z-10">
          1
        </span>
        <h5 class="text-base font-black text-cyan-600 dark:text-cyan-400 mt-2 mb-1 uppercase tracking-wide">
          Agáchate
        </h5>
        <p class="text-[0.68rem] text-center text-neutral-500 dark:text-neutral-400 mb-3 min-h-[2rem]">
          Baja al nivel del suelo sobre tus manos y rodillas.
        </p>
        <div class="h-32 w-full flex items-center justify-center overflow-hidden mb-3 bg-neutral-50 dark:bg-neutral-900/40 rounded border border-neutral-100 dark:border-neutral-850 p-2">
          <img 
            src="/assets/sismos_agachate_gen.png" 
            alt="Ilustración Agáchate" 
            class="max-h-full max-w-full object-contain transition-transform duration-300 group-hover:scale-105 rounded-md" 
          />
        </div>
        <div class="w-full bg-cyan-600 text-white text-[10px] font-bold text-center py-1.5 rounded uppercase tracking-wider">
          Evite Caídas
        </div>
      </div>

      {/* Connection arrow 1 -> 2 (Desktop) */}
      <div class="hidden md:flex absolute top-1/2 left-[30.5%] -translate-y-1/2 z-20 text-cyan-500/60 pointer-events-none">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="animate-pulse">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </div>

      {/* Step 2: Cubrete */}
      <div class="border-2 border-emerald-500/20 dark:border-emerald-500/10 rounded-xl p-4 flex flex-col items-center bg-emerald-50/5 dark:bg-emerald-950/5 hover:border-emerald-500 transition-all duration-300 relative group">
        <span class="absolute top-3 left-3 bg-emerald-600 text-white font-black text-xs w-6 h-6 flex items-center justify-center rounded-full shadow-sm z-10">
          2
        </span>
        <h5 class="text-base font-black text-emerald-600 dark:text-emerald-400 mt-2 mb-1 uppercase tracking-wide">
          Cúbrete
        </h5>
        <p class="text-[0.68rem] text-center text-neutral-500 dark:text-neutral-400 mb-3 min-h-[2rem]">
          Cubre tu cabeza y cuello debajo de un mueble resistente.
        </p>
        <div class="h-32 w-full flex items-center justify-center overflow-hidden mb-3 bg-neutral-50 dark:bg-neutral-900/40 rounded border border-neutral-100 dark:border-neutral-850 p-2">
          <img 
            src="/assets/sismos_cubrete_gen.png" 
            alt="Ilustración Cúbrete" 
            class="max-h-full max-w-full object-contain transition-transform duration-300 group-hover:scale-105 rounded-md" 
          />
        </div>
        <div class="w-full bg-emerald-600 text-white text-[10px] font-bold text-center py-1.5 rounded uppercase tracking-wider">
          Protéjase la Cabeza
        </div>
      </div>

      {/* Connection arrow 2 -> 3 (Desktop) */}
      <div class="hidden md:flex absolute top-1/2 left-[63.8%] -translate-y-1/2 z-20 text-emerald-500/60 pointer-events-none">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="animate-pulse">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </div>

      {/* Step 3: Sujetate */}
      <div class="border-2 border-purple-500/20 dark:border-purple-500/10 rounded-xl p-4 flex flex-col items-center bg-purple-50/5 dark:bg-purple-950/5 hover:border-purple-500 transition-all duration-300 relative group">
        <span class="absolute top-3 left-3 bg-purple-600 text-white font-black text-xs w-6 h-6 flex items-center justify-center rounded-full shadow-sm z-10">
          3
        </span>
        <h5 class="text-base font-black text-purple-600 dark:text-purple-400 mt-2 mb-1 uppercase tracking-wide">
          Sujétate
        </h5>
        <p class="text-[0.68rem] text-center text-neutral-500 dark:text-neutral-400 mb-3 min-h-[2rem]">
          Sujétate firmemente del mueble hasta que pase el sismo.
        </p>
        <div class="h-32 w-full flex items-center justify-center overflow-hidden mb-3 bg-neutral-50 dark:bg-neutral-900/40 rounded border border-neutral-100 dark:border-neutral-850 p-2">
          <img 
            src="/assets/sismos_sujetate_gen.png" 
            alt="Ilustración Sujétate" 
            class="max-h-full max-w-full object-contain transition-transform duration-300 group-hover:scale-105 rounded-md" 
          />
        </div>
        <div class="w-full bg-purple-600 text-white text-[10px] font-bold text-center py-1.5 rounded uppercase tracking-wider">
          Aguante Firme
        </div>
      </div>
    </div>
  </div>

  {/* Row 2: Durante el sismo, NO HAGAS ESTO (Coded Vector SVG icons) */}
  <div class="border border-red-200 dark:border-red-950/50 bg-red-50/20 dark:bg-red-950/5 p-4 sm:p-5 rounded-xl">
    <div class="flex items-center gap-2 text-red-600 dark:text-red-400 border-b border-red-100 dark:border-red-950 pb-2 mb-4">
      <AlertTriangle size={18} strokeWidth={2.5} class="animate-pulse" />
      <h4 class="text-sm sm:text-base font-black uppercase tracking-wider">Durante el sismo, NO HAGAS ESTO</h4>
    </div>
    
    <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 md:grid-cols-5">
      {/* Item 1: No corras */}
      <div class="flex flex-col items-center text-center p-4 border border-red-100 dark:border-red-950/50 bg-white dark:bg-neutral-900 rounded-lg shadow-sm hover:shadow transition-shadow relative group gap-3">
        <div class="relative w-16 h-16 rounded-full bg-white border-4 border-red-600 flex items-center justify-center shadow-md overflow-hidden flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
          <Footprints class="text-neutral-800 z-0 stroke-[2.5]" size={28} />
          <div class="absolute top-1/2 left-1/2 w-[140%] h-1.5 bg-red-600 -translate-x-1/2 -translate-y-1/2 rotate-45 z-10 pointer-events-none"></div>
        </div>
        <span class="text-[0.68rem] font-bold text-neutral-700 dark:text-neutral-300 leading-tight">No corras</span>
      </div>

      {/* Item 2: No uses elevadores */}
      <div class="flex flex-col items-center text-center p-4 border border-red-100 dark:border-red-950/50 bg-white dark:bg-neutral-900 rounded-lg shadow-sm hover:shadow transition-shadow relative group gap-3">
        <div class="relative w-16 h-16 rounded-full bg-white border-4 border-red-600 flex items-center justify-center shadow-md overflow-hidden flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
          <ArrowUpDown class="text-neutral-800 z-0 stroke-[2.5]" size={28} />
          <div class="absolute top-1/2 left-1/2 w-[140%] h-1.5 bg-red-600 -translate-x-1/2 -translate-y-1/2 rotate-45 z-10 pointer-events-none"></div>
        </div>
        <span class="text-[0.68rem] font-bold text-neutral-700 dark:text-neutral-300 leading-tight">No uses elevadores</span>
      </div>

      {/* Item 3: Aléjate de ventanas */}
      <div class="flex flex-col items-center text-center p-4 border border-red-100 dark:border-red-950/50 bg-white dark:bg-neutral-900 rounded-lg shadow-sm hover:shadow transition-shadow relative group gap-3">
        <div class="relative w-16 h-16 rounded-full bg-white border-4 border-red-600 flex items-center justify-center shadow-md overflow-hidden flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
          <Grid class="text-neutral-800 z-0 stroke-[2.5]" size={28} />
          <div class="absolute top-1/2 left-1/2 w-[140%] h-1.5 bg-red-600 -translate-x-1/2 -translate-y-1/2 rotate-45 z-10 pointer-events-none"></div>
        </div>
        <span class="text-[0.68rem] font-bold text-neutral-700 dark:text-neutral-300 leading-tight">Aléjate de ventanas</span>
      </div>

      {/* Item 4: Caída de objetos */}
      <div class="flex flex-col items-center text-center p-4 border border-red-100 dark:border-red-950/50 bg-white dark:bg-neutral-900 rounded-lg shadow-sm hover:shadow transition-shadow relative group gap-3">
        <div class="relative w-16 h-16 rounded-full bg-white border-4 border-red-600 flex items-center justify-center shadow-md overflow-hidden flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
          <Boxes class="text-neutral-800 z-0 stroke-[2.5]" size={28} />
          <div class="absolute top-1/2 left-1/2 w-[140%] h-1.5 bg-red-600 -translate-x-1/2 -translate-y-1/2 rotate-45 z-10 pointer-events-none"></div>
        </div>
        <span class="text-[0.68rem] font-bold text-neutral-700 dark:text-neutral-300 leading-tight">Evite caídas de objetos</span>
      </div>

      {/* Item 5: No uses el teléfono */}
      <div class="flex flex-col items-center text-center p-4 border border-red-100 dark:border-red-950/50 bg-white dark:bg-neutral-900 rounded-lg shadow-sm hover:shadow transition-shadow relative group gap-3">
        <div class="relative w-16 h-16 rounded-full bg-white border-4 border-red-600 flex items-center justify-center shadow-md overflow-hidden flex-shrink-0 group-hover:scale-105 transition-transform duration-300">
          <PhoneOff class="text-neutral-800 z-0 stroke-[2.5]" size={28} />
          <div class="absolute top-1/2 left-1/2 w-[140%] h-1.5 bg-red-600 -translate-x-1/2 -translate-y-1/2 rotate-45 z-10 pointer-events-none"></div>
        </div>
        <span class="text-[0.68rem] font-bold text-neutral-700 dark:text-neutral-300 leading-tight">No sature las líneas</span>
      </div>
    </div>
  </div>

  {/* Row 3: Bottom Sections (Recuerda, Si estas en..., Despues del sismo) */}
  <div class="grid gap-6 md:grid-cols-3">
    {/* Recuerda */}
    <div class="pc-card pc-hard-shadow-light border-l-4 border-amber-500 bg-white dark:bg-neutral-900 p-4 sm:p-5 flex flex-col justify-between border border-black/10 dark:border-white/5 rounded transition-transform hover:-translate-y-0.5 duration-300">
      <div class="flex gap-3 items-start">
        <div class="w-16 sm:w-20 shrink-0 overflow-hidden flex items-center justify-center rounded-lg border border-neutral-100 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/40 p-1.5">
          <img src="/assets/cropped_graphics/char_recuerda_girl.png" alt="Recuerda" class="w-full h-auto object-contain" />
        </div>
        <div class="flex-1">
          <h4 class="text-sm font-black text-amber-600 dark:text-amber-400 uppercase tracking-wide mb-2 flex items-center gap-1.5">
            <HelpCircle size={14} />
            <span>Recuerda</span>
          </h4>
          <ul class="space-y-1.5 text-[0.72rem] text-neutral-600 dark:text-neutral-400 font-semibold">
            <li class="flex items-center gap-1.5">⭐ Mantén la calma.</li>
            <li class="flex items-center gap-1.5">⭐ Sigue las indicaciones.</li>
            <li class="flex items-center gap-1.5">⭐ Confía en tu preparación.</li>
            <li class="flex items-center gap-1.5 text-amber-600 dark:text-amber-400 font-bold">⭐ ¡La prevención salva vidas!</li>
          </ul>
        </div>
      </div>
    </div>

    {/* Si estas en... */}
    <div class="pc-card pc-hard-shadow-light border-l-4 border-cyan-500 bg-white dark:bg-neutral-900 p-4 sm:p-5 flex flex-col border border-black/10 dark:border-white/5 rounded transition-transform hover:-translate-y-0.5 duration-300">
      <h4 class="text-sm font-black text-cyan-600 dark:text-cyan-400 uppercase tracking-wide mb-3 flex items-center gap-1.5">
        <Compass size={14} />
        <span>Si estás en...</span>
      </h4>
      <div class="space-y-3">
        {/* En Casa */}
        <div class="flex gap-3 items-center">
          <div class="w-10 h-10 shrink-0 bg-neutral-50 dark:bg-neutral-850 p-0.5 rounded border border-neutral-100 dark:border-neutral-800 flex items-center justify-center overflow-hidden">
            <img src="/assets/cropped_graphics/icon_casa.png" alt="En casa" class="max-h-full max-w-full object-contain" />
          </div>
          <div>
            <h5 class="text-[0.68rem] font-bold text-cyan-600 dark:text-cyan-400 uppercase tracking-wider">En casa</h5>
            <p class="text-[0.62rem] text-neutral-500 dark:text-neutral-400">Aléjate de objetos colgantes y quédate ahí.</p>
          </div>
        </div>

        {/* En la Escuela */}
        <div class="flex gap-3 items-center">
          <div class="w-10 h-10 shrink-0 bg-neutral-50 dark:bg-neutral-850 p-0.5 rounded border border-neutral-100 dark:border-neutral-800 flex items-center justify-center overflow-hidden">
            <img src="/assets/cropped_graphics/icon_escuela.png" alt="En la escuela" class="max-h-full max-w-full object-contain" />
          </div>
          <div>
            <h5 class="text-[0.68rem] font-bold text-cyan-600 dark:text-cyan-400 uppercase tracking-wider">En la escuela</h5>
            <p class="text-[0.62rem] text-neutral-500 dark:text-neutral-400">Siga las instrucciones de tu docente de forma calmada.</p>
          </div>
        </div>

        {/* En la Calle */}
        <div class="flex gap-3 items-center">
          <div class="w-10 h-10 shrink-0 bg-neutral-50 dark:bg-neutral-850 p-0.5 rounded border border-neutral-100 dark:border-neutral-800 flex items-center justify-center overflow-hidden">
            <img src="/assets/cropped_graphics/icon_calle.png" alt="En la calle" class="max-h-full max-w-full object-contain" />
          </div>
          <div>
            <h5 class="text-[0.68rem] font-bold text-cyan-600 dark:text-cyan-400 uppercase tracking-wider">En la calle</h5>
            <p class="text-[0.62rem] text-neutral-500 dark:text-neutral-400">Aléjate de edificios, postes, árboles y cables.</p>
          </div>
        </div>
      </div>
    </div>

    {/* Después del sismo (Updated with sismos_despues_gen.png) */}
    <div class="pc-card pc-hard-shadow-light border-l-4 border-emerald-500 bg-white dark:bg-neutral-900 p-4 sm:p-5 flex flex-col justify-between border border-black/10 dark:border-white/5 rounded transition-transform hover:-translate-y-0.5 duration-300">
      <div class="flex gap-3 items-start">
        <div class="flex-1">
          <h4 class="text-sm font-black text-emerald-600 dark:text-emerald-400 uppercase tracking-wide mb-2 flex items-center gap-1.5">
            <CheckCircle size={14} />
            <span>Después del sismo</span>
          </h4>
          <ul class="space-y-1.5 text-[0.72rem] text-neutral-600 dark:text-neutral-400 font-semibold">
            <li class="flex items-center gap-1.5">✔️ Revisa si hay daños a tu alrededor.</li>
            <li class="flex items-center gap-1.5">✔️ Ayuda a quienes lo necesitan.</li>
            <li class="flex items-center gap-1.5">✔️ Prepárate para posibles réplicas.</li>
          </ul>
        </div>
        <div class="w-16 sm:w-20 shrink-0 overflow-hidden flex items-center justify-center rounded-lg border border-neutral-100 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/40 p-1.5">
          <img src="/assets/sismos_despues_gen.png" alt="Después" class="w-full h-auto object-contain rounded" />
        </div>
      </div>
    </div>
  </div>
</div>
