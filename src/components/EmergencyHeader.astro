---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="relative overflow-hidden bg-[var(--color-secondary)] text-white">
  <div class="pc-dot-grid absolute inset-0 opacity-70"></div>
  <div
    class="absolute inset-0 bg-no-repeat opacity-12"
    style="background-image: url('/assets/LOGO-PC-NUEVO-e1754668914257.png'); background-size: min(54vw, 22rem); background-position: right -1.5rem top -1.5rem;"
  ></div>
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(15,33,71,0.18)_0%,rgba(15,33,71,0.94)_100%)]"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <div class="flex min-h-[12rem] flex-col justify-end gap-5 sm:min-h-[14rem]">
      <div class="max-w-4xl">
        <h1 class="text-3xl font-black leading-tight sm:text-5xl">
          {title}
        </h1>
        <p class="mt-4 max-w-3xl text-sm leading-6 text-white/88 sm:text-base sm:leading-7">
          {subtitle}
        </p>
      </div>
    </div>
  </div>
</section>
