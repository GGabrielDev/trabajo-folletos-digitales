---
import { House } from 'lucide-react';

interface Props {
  href?: string;
  tone?: 'dark' | 'light';
}

const { href = '/', tone = 'light' } = Astro.props;

const buttonClass =
  tone === 'dark'
    ? 'bg-white/10 border-white/15 text-slate-100 hover:bg-white/18'
    : 'bg-white/70 border-white/60 text-slate-700 hover:bg-white';
---

<a
  href={href}
  class:list={[
    'inline-flex items-center gap-1.5 rounded-full border px-3 py-2 text-[0.7rem] font-semibold transition-colors',
    buttonClass,
  ]}
>
  <House size={14} />
  <span>Inicio</span>
</a>
